{
  "name": "sergamon",
  "version": "1.160.0",
  "type": "module",
  "description": "Pixel-perfect monospaced font for code. No ligatures. No surprises.",
  "scripts": {
    "validate": "tsx src/validate-glyphs.ts",
    "build": "npm run build:font && npm run build:previews",
    "build:font": "npm run validate && tsx src/build-font.ts",
    "build:previews": "node src/generate-previews.cjs",
    "site": "npm run build && cp build/*.woff2 site/fonts/",
    "dev": "tsx src/dev-preview.ts",
    "clean": "rm -rf build/"
  },
  "devDependencies": {
    "@napi-rs/canvas": "^0.1.0",
    "@types/node": "^25.2.2",
    "chokidar": "^3.6.0",
    "opentype.js": "^1.3.4",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "wawoff2": "^2.0.1"
  },
  "author": {
    "name": "Sergio García Mondaray",
    "url": "https://sgmonda.com",
    "email": "sgmonda@gmail.com"
  },
  "license": "OFL-1.1",
  "engines": {
    "node": ">=20"
  }
}
